# Supabase — get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Site URL — used for OAuth redirects (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth (Drive upload for heavy files) — Google Cloud Console → APIs &
# Services → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized redirect URI must be: <NEXT_PUBLIC_SITE_URL>/api/google-drive/callback
# NEVER use a service-account key here — personal Gmail accounts have no Drive
# storage quota for service accounts (confirmed: "Service Accounts do not have
# storage quota" error). OAuth delegation (this) uploads into the teacher's own
# Drive using their own quota.
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
